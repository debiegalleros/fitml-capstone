# Python
venv/
__pycache__/
*.pyc
.ipynb_checkpoints/

# Data (raw + catalog are large/licensed, never commit — keep folder structure via .gitkeep)
data/raw/*
!data/raw/.gitkeep
# Exception: hand-transcribed Uniqlo men's size chart — tiny, not a licensed
# download, required to reproduce the men's extension
!data/raw/mens_size_charts.csv
data/catalog/*
!data/catalog/.gitkeep
# Exceptions: small derived CSVs that record the catalog curation and are
# needed to reproduce/serve the exact catalog (images stay ignored)
!data/catalog/candidates.csv
!data/catalog/variants.csv
!data/catalog/metadata.csv
!data/catalog/isolation_report.csv

# Kaggle credentials
kaggle.json
.kaggle/

# Uploaded user photos (privacy)
backend/uploads/

# Env / secrets
.env
*.env

# OS
.DS_Store

# Model artifacts that are large (keep comparison.csv, small joblib files can stay if small)
*.h5
# 50MB — reproducible via src/train_models.py (fixed seed)
models/random_forest.joblib

# Editor
.vscode/
.idea/

# Claude Code local tooling state
.claude/
